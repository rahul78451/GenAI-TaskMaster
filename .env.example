# Environment Configuration Template
# Copy this file to .env and update with your actual values
# NEVER commit .env file with real credentials to version control

# ==================== DATABASE ====================
# SQLite (development/testing)
DATABASE_URL=sqlite:///./app.db

# PostgreSQL (production on Google Cloud)
# DATABASE_URL=postgresql://username:password@cloud-sql-instance:5432/genai_db
# DATABASE_URL=postgresql://genai_user:password@35.192.123.456:5432/genai_db

# ==================== GOOGLE CLOUD ====================
# Google API Key for Generative AI
GOOGLE_API_KEY=your_google_api_key_here

# Google Cloud Project ID
GCP_PROJECT_ID=genai-task-manager

# Google Cloud SQL Connection (for Cloud Run)
CLOUD_SQL_CONNECTION_NAME=genai-task-manager:us-central1:genai-db

# ==================== APPLICATION ====================
# Debug mode (set to False in production)
DEBUG=False

# Application environment
ENVIRONMENT=production

# ==================== SERVER ====================
# Server host and port
HOST=0.0.0.0
PORT=8080

# ==================== SECURITY ====================
# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=*

# Secret key for JWT tokens
SECRET_KEY=your_secret_key_here_change_in_production

# ==================== LOGGING ====================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ==================== EXTERNAL SERVICES ====================
# OpenAI API Key (if using OpenAI instead of Google)
OPENAI_API_KEY=your_openai_key_here

# ==================== DATABASE BACKUP ====================
# Enable automatic backups
ENABLE_BACKUPS=true

# Backup location (Google Cloud Storage)
BACKUP_BUCKET=gs://genai-task-manager-backups/

# ==================== EMAIL (future feature) ====================
# SMTP server configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# ==================== MONITORING ====================
# Enable Google Cloud Monitoring
ENABLE_MONITORING=true

# Enable error reporting
ENABLE_ERROR_REPORTING=true
